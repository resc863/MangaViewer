<Page
    x:Class="MangaViewer.Pages.MangaReaderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:viewmodels="using:MangaViewer.ViewModels"
    mc:Ignorable="d" 
    Background="Transparent">
    <Grid Background="Transparent">
        <Grid x:Name="ReaderLayoutRoot"
              Background="Transparent"
              SizeChanged="ReaderSplitView_SizeChanged"
              Canvas.ZIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="ReaderPaneColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="ReaderPaneHost"
                  Grid.Column="1"
                  Width="160"
                  Visibility="Collapsed">
                <!-- Resizable pane: left grip thumb + content listview -->
                <Grid Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Drag grip -->
                    <Thumb x:Name="PaneResizeThumb"
                           Grid.Column="0"
                           Background="Transparent"
                           DragDelta="PaneResizeThumb_DragDelta"
                           DragCompleted="PaneResizeThumb_DragCompleted">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Grid Background="Transparent">
                                    <!-- visual handle line -->
                                    <Border Width="1"
                                            HorizontalAlignment="Right"
                                            Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                                </Grid>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>

                    <Grid Grid.Column="1">
                        <!-- Thumbnails list -->
                        <ListView x:Name="ThumbnailsList"
                                  Background="Transparent"
                                  SelectionMode="Single"
                                  SelectionChanged="ThumbnailsList_SelectionChanged"
                                  ContainerContentChanging="ThumbnailsList_ContainerContentChanging">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:MangaPageViewModel">
                                    <Grid>
                                        <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Height="120" Stretch="Uniform" Margin="5"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Border Background="Transparent"
                                IsHitTestVisible="False"
                                Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8"
                                        MaxWidth="180">
                                <FontIcon Glyph="&#xE735;"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="28"
                                          HorizontalAlignment="Center"
                                          Opacity="0.8"/>
                                <TextBlock Text="북마크가 없습니다"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="현재 페이지를 북마크에 추가하면 여기에서만 모아 볼 수 있습니다."
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Opacity="0.8"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Grid x:Name="PageSlideHost" Grid.Column="0" Background="Transparent">
                    <Grid x:Name="PageContentRoot" Background="Transparent" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="PageTranslate" />
                        </Grid.RenderTransform>
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: Images -->
                            <Grid Grid.Row="0" Background="Transparent">
                                <!-- Single Page Mode -->
                                <Grid x:Name="SingleWrapper" Visibility="Collapsed" SizeChanged="OnSingleOcrContainerSizeChanged" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image x:Name="SingleImage" Stretch="Uniform" SizeChanged="OnSingleImageSizeChanged" />
                                    <Canvas x:Name="SingleOverlay" Canvas.ZIndex="1" Background="Transparent" />
                                </Grid>
                                <!-- Two Page Mode -->
                                <Grid x:Name="TwoPageWrapper" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid x:Name="LeftWrapper" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" SizeChanged="OnLeftOcrContainerSizeChanged" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                                        <Image x:Name="LeftImage" Stretch="Uniform" SizeChanged="OnLeftImageSizeChanged" />
                                        <Canvas x:Name="LeftOverlay" Canvas.ZIndex="1" Background="Transparent" />
                                    </Grid>
                                    <Grid x:Name="RightWrapper" Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center" SizeChanged="OnRightOcrContainerSizeChanged" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                                        <Image x:Name="RightImage" Stretch="Uniform" SizeChanged="OnRightImageSizeChanged" />
                                        <Canvas x:Name="RightOverlay" Canvas.ZIndex="1" Background="Transparent" />
                                    </Grid>
                                </Grid>
                            </Grid>

                        </Grid>
                    </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
