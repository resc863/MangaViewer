{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "restore",
			"command": "dotnet",
			"type": "process",
			"args": [
				"restore",
				"MangaViewer/MangaViewer.csproj"
			],
			"problemMatcher": "$msCompile",
			"group": "build"
		},
		{
			"label": "build Debug x64",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"MangaViewer/MangaViewer.csproj",
				"-c",
				"Debug",
				"-f",
				"net10.0-windows10.0.26100.0",
				"-p:Platform=x64"
			],
			"problemMatcher": "$msCompile",
			"group": "build",
			"dependsOn": [
				"restore"
			],
			"detail": "Build WinUI3 app (x64 Debug)"
		},
		{
			"label": "build Debug x86",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"MangaViewer/MangaViewer.csproj",
				"-c",
				"Debug",
				"-f",
				"net10.0-windows10.0.26100.0",
				"-p:Platform=x86"
			],
			"problemMatcher": "$msCompile",
			"group": "build",
			"dependsOn": [
				"restore"
			],
			"detail": "Build WinUI3 app (x86 Debug)"
		},
		{
			"label": "build Debug ARM64",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"MangaViewer/MangaViewer.csproj",
				"-c",
				"Debug",
				"-f",
				"net10.0-windows10.0.26100.0",
				"-p:Platform=ARM64"
			],
			"problemMatcher": "$msCompile",
			"group": "build",
			"dependsOn": [
				"restore"
			],
			"detail": "Build WinUI3 app (ARM64 Debug)"
		},
		{
			"label": "run Debug x64 with winapp",
			"command": "pwsh",
			"type": "process",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/run_winapp.ps1",
				"-NoBuild",
				"-Detach"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"dependsOn": [
				"build Debug x64"
			],
			"detail": "Run WinUI3 app through winapp CLI debug identity"
		}
	]
}
